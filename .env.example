# ----- Mama's Cookies — server environment -----
# Copy to `.env` for local dev, or set these in your Vercel project settings.
# Everything has a safe local default.

# Port the local Express server listens on (not used on Vercel).
PORT=3001

# ----- Database (libSQL / Turso) -----
# Local dev defaults to an embedded file (file:./data.sqlite) and needs nothing.
# For a hosted, persistent database (e.g. on Vercel) create a free Turso DB and
# set these two — get them with:  turso db show <name> --url  /  turso db tokens create <name>
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Admin login + token signing secret. CHANGE THESE before going live.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=mama123
AUTH_SECRET=please-change-this-to-a-long-random-string

# Order economics (PKR). Keep in sync with src/lib/brand.ts for display.
DELIVERY_FEE=150
FREE_DELIVERY_OVER=3000

# Payments. "mock" = built-in sandbox gateway (no keys needed).
# Set to "live" and fill the Easypaisa values below to take real payments.
PAYMENTS_MODE=mock

# Easypaisa merchant credentials (only used when PAYMENTS_MODE=live).
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=
EASYPAISA_POST_URL=https://easypay.easypaisa.com.pk/easypay/Index.jsf

# Public base URL for payment return links (optional; auto-detected from the
# request on single-host deploys). On Vercel, set this to your deployment URL
# if payment redirects ever land on the wrong host.
# APP_URL=https://your-app.vercel.app
